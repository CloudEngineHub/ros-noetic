diff --git a/lisp/comp/comp.l b/lisp/comp/comp.l
index dfb72595..5cdec7a8 100644
--- a/lisp/comp/comp.l
+++ b/lisp/comp/comp.l
@@ -34,15 +34,16 @@
 (defparameter *pic* t)
 (defparameter *kernel* nil)
 ;(defparameter *cc* (if (member :gcc *features*) "gcc" "cc"))
-(defparameter *cc* 
-  (cond ((member :sh4 *features*)
+(defparameter *cc*
+  (or (unix:getenv "CC")
+      (cond ((member :sh4 *features*)
 	 "sh4-linux-gcc -g")
 	((member :ia32 *features*) 
 	 "gcc -g -m32")
 	((member :gcc *features*)
 	   "gcc -g")
 	((member :alpha *features*) "cc -ieee_with_inexact" )
-	(t "cc")))
+	(t "cc"))))
 
 (defvar comp nil "$Id$")
 (defvar trans)
@@ -1390,7 +1391,10 @@
 				      ((memq :i386 *features*)
 				       "; gcc -shared -Xlinker -build-id -o ")
 				      (t
-				       "; ld -shared -build-id -o "))
+				       (concatenate string
+						    "; "
+						    (or (unix:getenv "CC") "gcc")
+						    " -shared -Wl,-build-id -o ")))
 				(namestring file.so)
 				" "
 				(namestring file.o))
diff --git a/lisp/image/jpeg/makefile b/lisp/image/jpeg/makefile
index 223f9055..f073c5c7 100644
--- a/lisp/image/jpeg/makefile
+++ b/lisp/image/jpeg/makefile
@@ -1,11 +1,13 @@
