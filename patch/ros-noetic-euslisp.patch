   OS=Cygwin
 endif
 ifeq ($(OS), Linux)
@@ -17,12 +19,12 @@ else
 endif
 
 ifneq ($(OS), Darwin)
- LD = gcc -shared 
+ LD = $(CC) -shared
 else
- LD = gcc -dynamiclib
+ LD = $(CC) -dynamiclib
 endif
 
-ifeq ($(shell gcc -dumpmachine | sed 's/\(.*\)-.*-.*/\1/'), x86_64)
+ifeq ($(shell $(CC) -dumpmachine | sed 's/\(.*\)-.*-.*/\1/'), x86_64)
 ifneq ($(ARCHDIR), Linux64)
 ifneq ($(ARCHDIR), Darwin)
 CC += -m32
@@ -42,6 +44,10 @@ endif
