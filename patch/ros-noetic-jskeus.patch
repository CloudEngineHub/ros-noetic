diff --git a/irteus/Makefile b/irteus/Makefile
index d86193f..a02dbf3 100644
--- a/irteus/Makefile
+++ b/irteus/Makefile
@@ -153,7 +153,18 @@ IRTIMGCOBJECTS=$(INSTALLOBJDIR)/euspng.$(OSFX)
 IRTGLCOBJECTS=$(INSTALLOBJDIR)/irtglc.$(OSFX)
