-all: defun.h $(LIBNR) $(LIBIRTEUS) $(LIBIRTEUSG) $(LIBIRTEUSX) $(LIBIRTEUSIMG) $(LIBIRTEUSGL) make-link install-irtext.l
+EUSGL_BIN=
+ifneq ($(shell [ -x "$(BINDIR)/eusgl$(ESFX)" ] && echo yes),)
+EUSGL_BIN=$(BINDIR)/eusgl$(ESFX)
+IRTEUS_GL_LIBS=$(LIBIRTEUSG) $(LIBIRTEUSGL)
+else ifneq ($(shell [ -x "$(BINDIR)/eusg$(ESFX)" ] && echo yes),)
