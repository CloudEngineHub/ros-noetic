+all: defun.h $(LIBNR) $(LIBIRTEUS) $(IRTEUS_GL_LIBS) $(LIBIRTEUSX) $(LIBIRTEUSIMG) make-link install-irtext.l
 
 .PHONY: defun.h
 defun.h:
@@ -187,7 +198,7 @@ $(IRTEUSOBJS) $(INSTALLOBJDIR)/compile_irt.log: $(IRTEUS_L)
 
 $(IRTEUSGOBJS): $(INSTALLOBJDIR)/compile_irtg.log
